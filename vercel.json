{
  "rewrites": [
    {
      "source": "/iclock/cdata",
      "destination": "/api/attendance"
    },
    {
      "source": "/device/cdata",
      "destination": "/api/attendance"
    }
  ],
  "crons": [
    {
      "path": "/api/send-birthday-emails",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/scheduler/daily",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/scheduler/attendance-summary",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/reminders?type=morning",
      "schedule": "45 3 * * 1-5"
    },
    {
      "path": "/api/cron/reminders?type=evening",
      "schedule": "30 11 * * 1-5"
    },
    {
      "path": "/api/cron/ai-workflow",
      "schedule": "30 12 * * 1-5"
    }
  ]
}